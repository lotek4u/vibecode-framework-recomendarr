# Copy this file to .env in the same Docker/ directory and fill in your values.
# These variables are passed into the container at runtime.

# Override the default config and DB paths (optional — defaults shown)
CONFIG_PATH=/config/config.yaml
DB_PATH=/config/recommendarr.db

# Flask secret key — set this to a long random string in production.
# If not set, a key is auto-generated and stored in /config/secret.key
SECRET_KEY=change-me-to-a-long-random-string-or-get-owned-by-someone-who-will-change-it-for-you
